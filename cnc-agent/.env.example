# MES Backend
BACKEND_URL=http://localhost:3000
ADMIN_USERNAME=admin
ADMIN_PASSWORD=jouw_wachtwoord_hier

# TNCcmd
TNCCMD_PATH=C:\Program Files (x86)\HEIDENHAIN\TNCremo\TNCcmd.exe
TNCCMD_TIMEOUT_MS=30000

# Interval in minuten (alleen voor continue modus)
SYNC_INTERVAL_MIN=30

# HTTP poort voor on-demand sync (bereikbaar voor de MES backend)
AGENT_PORT=3099

# WinTool database (optioneel) — volledig pad naar het .db bestand op deze PC
# De agent detecteert automatisch wijzigingen en uploadt naar de MES backend
WINTOOL_DB_PATH=

# CNC state polling (machine events: gereedschapwissels, programma's, alarmen)
# Elke CNC_STATE_POLL_INTERVAL_MS milliseconden wordt de status van elke Freesmachine gepolled
CNC_STATE_POLL_ENABLED=true
CNC_STATE_POLL_INTERVAL_MS=10000

# TNCremo logboek monitoring (alarms, reset, machine start vanuit TNCremo logbestanden)
# Zet TNCREMO_LOGBOOK_ENABLED=true als TNCremo op dezelfde PC draait als de agent
# Pad verschilt per Windows-gebruiker — standaard: %TEMP%\TNCremo\Logbook
TNCREMO_LOGBOOK_ENABLED=false
TNCREMO_LOGBOOK_PATH=C:\Users\ArneNijman\AppData\Local\Temp\TNCremo\Logbook
TNCREMO_POLL_INTERVAL_MS=60000
